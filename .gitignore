# Notion Infrastructure .gitignore

# Secrets and tokens
*.env
token.env
.notion-token
secrets/

# Generated configs
*.conf
!examples/*.conf

# Backups
*.bak
*.backup

# Logs
*.log

# OS files
.DS_Store
Thumbs.db

# Editor files
*.swp
*.swo
*~
.vscode/
.idea/

# Python
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
*.egg-info/

# Temporary files
tmp/
temp/
.claude
